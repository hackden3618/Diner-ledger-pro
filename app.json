{
  "expo": {
    "name": "Diner Ledger",
    "slug": "Hotel_Inventory",
    "version": "2.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dinerledger",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#31CE78",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.hackden3618.Hotel_Inventory"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#066B35",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 242,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 242
          },
          "ios": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 242
          }
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#31CE78"
        }
      ],
      "expo-sqlite",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app needs access to your photos to let you set images for meals."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3b511026-df5d-4765-bdd4-04e29262a374"
      }
    }
  }
}
